{
    # global settings
    admin off  # off admin API (Security)
}

# for development (localhost)
:80 {
    # log
    log {
        output stdout
        format console
        level INFO
    }
    
    # WebSocket
    @websocket {
        path /ws
    }
    handle @websocket {
        reverse_proxy api-gateway:8083 {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
            header_up X-Forwarded-Proto {scheme}
        }
    }
    
    # API (strip /api prefix)
    handle /api/* {
        uri strip_prefix /api
        reverse_proxy api-gateway:8083 {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
            header_up X-Forwarded-Proto {scheme}
        }
    }
    
    # Frontend
    handle {
        root * /var/www/frontend
        try_files {path} /index.html
        file_server
    }
}

